{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/dangerous-cmd-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/commit-quality.sh",
            "type": "command"
          }
        ],
        "if": "Bash(git commit*)",
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/secret-scanner.sh",
            "type": "command"
          },
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/file-safety-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ]
  }
}
