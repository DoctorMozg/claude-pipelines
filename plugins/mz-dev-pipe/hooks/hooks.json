{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/detect-tooling.sh",
            "once": true,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/completion-gate.sh",
            "type": "command"
          }
        ]
      }
    ]
  }
}
